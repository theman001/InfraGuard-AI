# 국가법령정보 Open API OC ID (필수 — Phase 1부터 사용)
# https://open.law.go.kr 에서 발급
LAW_OC_ID=your_law_oc_id_here

# Claude API 키 (필수 — Phase 3부터 사용)
# https://console.anthropic.com 에서 발급
CLAUDE_API_KEY=your_claude_api_key_here

# ChromaDB 컬렉션 이름 (기본값: legal_advisory)
CHROMA_COLLECTION=legal_advisory

# 데이터 저장 경로 (기본값: 프로젝트 내 상대경로)
# Docker/NAS 환경에서 외부 볼륨 마운트 시 절대경로로 지정
# DB_PATH=/data/infraguard/app.db
# CHROMA_PATH=/data/infraguard/chroma_db

# 암호화 키 (필수 — python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 로 생성)
ENCRYPTION_KEY=your_encryption_key_here
